#!/bin/bash
# AppRun — AppImage 入口脚本
# 把只读 data/ 复制到用户目录，cd 过去启动二进制

# $APPDIR 由 AppImage 运行时自动设置
if [ -z "$APPDIR" ]; then
    APPDIR="$(cd "$(dirname "$0")" && pwd -P)"
fi

RO_DATA="$APPDIR/usr/share/recite-english"
BIN="$APPDIR/usr/bin/main_c"
USER_DATA="$HOME/.local/share/recite-english"

if [ ! -d "$RO_DATA" ]; then
    echo "错误: 数据目录不存在: $RO_DATA" >&2
    exit 1
fi
if [ ! -x "$BIN" ]; then
    echo "错误: 找不到可执行文件: $BIN" >&2
    exit 1
fi

# 首次运行：整体复制
if [ ! -d "$USER_DATA" ]; then
    mkdir -p "$USER_DATA"
    cp -r "$RO_DATA"/* "$USER_DATA"/
fi

# 每次覆盖词库，确保更新生效（进度/账号文件不会被覆盖）
cp "$RO_DATA/data/words.txt" "$USER_DATA/data/words.txt"

cd "$USER_DATA" || exit 1
exec "$BIN" "$@"
