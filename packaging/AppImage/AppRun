#!/bin/bash
# AppRun — AppImage 入口脚本
# 把只读 data/ 复制到用户目录，然后 cd 过去启动二进制

# $APPDIR 由 AppImage 运行时自动设置
if [ -z "$APPDIR" ]; then
    APPDIR="$(cd "$(dirname "$0")" && pwd -P)"
fi

RO_DATA_DIR="$APPDIR/usr/share/recite-english"
BIN="$APPDIR/usr/bin/main_c"
USER_DATA="$HOME/.local/share/recite-english"

if [ ! -d "$RO_DATA_DIR" ]; then
    echo "错误: 数据目录不存在: $RO_DATA_DIR" >&2
    exit 1
fi

if [ ! -x "$BIN" ]; then
    echo "错误: 找不到可执行文件: $BIN" >&2
    exit 1
fi

# 首次运行：把只读数据复制到可写用户目录
if [ ! -d "$USER_DATA" ]; then
    mkdir -p "$USER_DATA"
    cp -r "$RO_DATA_DIR"/* "$USER_DATA"/
fi

cd "$USER_DATA" || exit 1
exec "$BIN" "$@"
